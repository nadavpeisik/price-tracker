# ============================================================
# Spring Boot / Maven – Price Tracker Backend
# ============================================================

# ----- Maven build output -----
target/
!**/src/main/**/target/
!**/src/test/**/target/

# Maven wrapper jar (properties file IS tracked; jar is not)
.mvn/wrapper/maven-wrapper.jar

# ----- Secrets & local environment -----
# Never commit credentials, API keys, or local overrides.
# Use application-local.properties or .env for local secrets.
*.env
.env
.env.*
!.env.example

# Spring profile overrides that contain local/secret values
application-local.properties
application-local.yml
application-secret.properties
application-secret.yml
**/src/main/resources/application-local.*
**/src/main/resources/application-secret.*

# ----- IntelliJ IDEA -----
# Ignore the entire .idea directory.
# Shareable settings (code style, inspections) should be exported
# to .editorconfig or committed as standalone XML files instead.
.idea/
*.iws
*.iml
*.ipr

# ----- Eclipse / STS -----
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ----- NetBeans -----
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ----- VS Code -----
.vscode/

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride
._*

# ----- Logs -----
*.log
logs/
spring.log

# ----- Compiled / packaged artifacts -----
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# ----- JVM crash logs -----
hs_err_pid*
replay_pid*

# ----- Docker -----
# compose.yaml IS tracked (infrastructure-as-code).
# Ignore any local docker override files.
compose.override.yaml
docker-compose.override.yml

# ----- Misc -----
# Spring Initializr readme – informational only, safe to ignore
HELP.md
